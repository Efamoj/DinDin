# ─── Banco de dados ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://dindin:dindin@localhost:5432/dindin?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Anthropic (IA) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ─── OpenAI Whisper (transcrição de áudio) ───────────────────────────────────
# Opcional — sem isso, áudios não serão transcritos
OPENAI_API_KEY="sk-..."

# ─── WhatsApp (Baileys) ──────────────────────────────────────────────────────
WA_SESSION_DIR="./sessions"
WA_SESSION_NAME="dindin"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000       # janela de 1 minuto
RATE_LIMIT_MAX_MESSAGES=20       # máximo 20 msgs por janela

# ─── PIX (pagamentos) ────────────────────────────────────────────────────────
PIX_KEY="seu-email@dominio.com"

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="info"
